# GitHub OAuth App credentials (create at https://github.com/settings/developers)
VITE_GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Repo to commit guide changes to (owner/repo format)
VITE_GITHUB_REPO=remote-pass/remotepass-apis-document

# Branch to commit to
VITE_GITHUB_BRANCH=staging
